<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Couleurs de fond -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F0F0F0"/>

    <!-- Couleurs de texte -->
    <SolidColorBrush x:Key="ForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#666666"/>

    <!-- Couleurs de bordure -->
    <SolidColorBrush x:Key="BorderBrush" Color="#CCCCCC"/>

    <!-- Couleurs de menu -->
    <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="MenuForegroundBrush" Color="#000000"/>

</ResourceDictionary>