<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Couleurs de fond -->
  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E"/>
  <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D30"/>

  <!-- Couleurs de texte -->
  <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#CCCCCC"/>

  <!-- Couleurs de bordure -->
  <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>

  <!-- Couleurs de menu -->
  <SolidColorBrush x:Key="MenuBackgroundBrush" Color="#2D2D30"/>
  <SolidColorBrush x:Key="MenuForegroundBrush" Color="#FFFFFF"/>
  <Style TargetType="Menu">
    <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}"/>
    <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
  </Style>

  <Style TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource MenuForegroundBrush}"/>
    <Setter Property="Background" Value="{DynamicResource MenuBackgroundBrush}"/>
  </Style>

</ResourceDictionary>